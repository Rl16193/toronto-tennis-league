rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Users Collection
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId); // Owner can read their profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ===============================================================
    // Stats Collection
    // ===============================================================
    match /stats/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ===============================================================
    // Preferences Collection
    // ===============================================================
    match /preferences/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ===============================================================
    // Events Collection
    // ===============================================================
    match /events/{eventId} {
      allow read: if true; // Events are public
      allow write: if false; // Only backend/admin can manage events
    }

    // ===============================================================
    // Event Participants Collection
    // ===============================================================
    match /event_participants/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                       request.resource.data.user_id == request.auth.uid &&
                       request.resource.data.event_id is string &&
                       request.resource.data.tournament_choice is string &&
                       request.resource.data.doubles is string &&
                       request.resource.data.partner_in_app is string &&
                       request.resource.data.skill is number &&
                       request.resource.data.createdAt is string;
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }
  }
}
